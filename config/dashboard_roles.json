  "rules": {
    "twitchNativeActions": "Mods und SuperMods dürfen über das Dashboard bei Twitch nur Aktionen ausführen, die ihr eigener Twitch-Account im Kanal auch ausführen darf. Dashboard-Rollen erweitern keine Twitch-Rechte. Alle Twitch-Moderationsaktionen laufen über den OAuth-Token des eingeloggten Mods und werden im Mod-Log gespeichert.",
    "dashboardActions": "Nicht-Twitch-Aktionen werden über Dashboard-Permissions geprüft.",
    "localAdminActions": "Lokale Admin-Aktionen brauchen zusätzlich erlaubte lokale IP/LAN-Herkunft. Buttons im Frontend reichen nicht als Schutz; Backend muss prüfen.",
    "preparedOnly": "Rollen/Permissions sind vorbereitet, aber noch nicht live aktiviert. UI darf sie anzeigen, Backend muss später jede Aktion final prüfen.",
    "twitchLogin": "Twitch-Login wird vorbereitet, aber echte Mod-/Chat-Aktionen werden erst später aktiviert."
  },
  "roles": {
