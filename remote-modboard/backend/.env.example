# ForrestCGN Remote Modboard - example only
# Copy to /etc/stream-control-center/remote-modboard.env on the webserver.
# Never commit real secrets.

NODE_ENV=production
REMOTE_MODBOARD_HOST=127.0.0.1
REMOTE_MODBOARD_PORT=3010
REMOTE_PUBLIC_BASE_URL=https://mods.forrestcgn.de

# MariaDB 11.8.6 on web.cgn.community
DB_ENGINE=MariaDB 11.8.6
DB_HOST=localhost
DB_PORT=3306
DB_NAME=c1stream_control
DB_USER=c3stream_control
DB_PASSWORD=change-me-on-server-only

# Future use only. Do not expose in frontend or logs.
SESSION_SECRET=change-me-on-server-only
AGENT_SHARED_SECRET=change-me-on-server-only
LOG_LEVEL=info
