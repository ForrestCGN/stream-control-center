# RDAP5H example only. Copy to /etc/stream-control-center/remote-modboard.env on the server.
# Do not commit the real ENV file. Do not post secrets in chat.

NODE_ENV=production
REMOTE_MODBOARD_HOST=127.0.0.1
REMOTE_MODBOARD_PORT=3010
REMOTE_MODBOARD_MODE=online
# Fuer lokalen LAN-Betrieb spaeter: REMOTE_MODBOARD_HOST=0.0.0.0 und REMOTE_MODBOARD_MODE=local
REMOTE_MODBOARD_LOCAL_ALLOWED_CIDRS=127.0.0.1/32
REMOTE_PUBLIC_BASE_URL=https://mods.forrestcgn.de

DB_ENGINE=MariaDB 11.8.6
DB_HOST=localhost
DB_PORT=3306
DB_NAME=c1stream_control
DB_USER=c3stream_control
DB_PASSWORD=CHANGE_ME_ON_SERVER_ONLY

# Reserved for later auth/agent steps. Do not use productively in RDAP5H.
SESSION_SECRET=CHANGE_ME_ON_SERVER_ONLY
AGENT_SHARED_SECRET=CHANGE_ME_ON_SERVER_ONLY
