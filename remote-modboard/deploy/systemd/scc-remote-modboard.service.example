[Unit]
Description=ForrestCGN Stream Control Center Remote Modboard
After=network.target

[Service]
Type=simple
User=sccremote
Group=sccremote
WorkingDirectory=/opt/stream-control-center/remote-modboard/backend
EnvironmentFile=/etc/stream-control-center/remote-modboard.env
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/stream-control-center/remote-modboard/backend

[Install]
WantedBy=multi-user.target
